# Copy this file to .env (or .env.local) and fill in your real values.
# .env files are gitignored — your secrets will NOT be committed.

# Formspree endpoint — used for Contact form AND Career applications.
# Sign up free at https://formspree.io/, create a form, paste the URL below.
# Example: VITE_FORMSPREE_URL=https://formspree.io/f/xpwzngrk
VITE_FORMSPREE_URL=https://formspree.io/f/YOUR_FORM_ID_HERE

# Google Analytics 4 Measurement ID (optional). Format: G-XXXXXXXXXX
# Sign up at https://analytics.google.com/, create a property, copy the ID.
VITE_GA_MEASUREMENT_ID=

# Google Gemini API key (optional, only needed for future AI features).
GEMINI_API_KEY=
